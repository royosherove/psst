{
  "name": "psst-cli",
  "version": "0.6.3",
  "description": "AI-native secrets manager. Agents use secrets without seeing them.",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "psst": "./src/main.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build --compile src/main.ts --outfile psst",
    "build:types": "tsc",
    "prepublishOnly": "./node_modules/.bin/tsc",
    "build:linux": "bun build --compile --target=bun-linux-x64 src/main.ts --outfile psst-linux-x64",
    "build:mac-arm": "bun build --compile --target=bun-darwin-arm64 src/main.ts --outfile psst-darwin-arm64",
    "build:mac-x64": "bun build --compile --target=bun-darwin-x64 src/main.ts --outfile psst-darwin-x64",
    "test": "bun test",
    "format": "bunx biome format --write src/",
    "lint": "bunx biome lint src/",
    "check": "bunx biome check src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/psst.git"
  },
  "homepage": "https://github.com/Michaelliv/psst#readme",
  "bugs": {
    "url": "https://github.com/Michaelliv/psst/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },

  "keywords": [
    "secrets",
    "cli",
    "agent",
    "ai",
    "security",
    "keychain",
    "encryption",
    "secrets-management",
    "claude",
    "cursor",
    "aider"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2"
  }
}
